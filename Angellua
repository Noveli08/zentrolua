-- OG SNIPER 🔫 (FIXED)
------------------------------------------------
local noScopeConn
local ogEnabled = false
local originalFOV = workspace.CurrentCamera.FieldOfView

addBtn("OG Sniper 🔫",
function()
    ogEnabled = true

    local camera = workspace.CurrentCamera
    originalFOV = camera.FieldOfView

    noScopeConn = RunService.RenderStepped:Connect(function()
        if not ogEnabled then return end

        local char = player.Character
        if not char then return end

        local tool = char:FindFirstChildOfClass("Tool")
        if tool and tool.Name:lower():find("sniper") then

            -- Scope nur EINMAL entfernen
            if tool:GetAttribute("ScopeRemoved") ~= true then
                tool:SetAttribute("ScopeRemoved", true)

                if tool:FindFirstChild("Scope") then
                    tool.Scope:Destroy()
                end

                tool:SetAttribute("Scope", false)
            end

            -- FOV nur setzen wenn nötig
            if camera.FieldOfView ~= 70 then
                camera.FieldOfView = 70
            end
        end
    end)
end,

function()
    ogEnabled = false

    if noScopeConn then
        noScopeConn:Disconnect()
        noScopeConn = nil
    end

    -- FOV reset sauber
    workspace.CurrentCamera.FieldOfView = originalFOV
end)

