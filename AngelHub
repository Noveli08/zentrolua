-- BUTTON CREATOR
------------------------------------------------
local function addBtn(text,callback)

    local b = Instance.new("TextButton",holder)
    b.Size = UDim2.new(1,0,0,45)
    b.BackgroundColor3 = Color3.fromRGB(30,60,90) -- Dunkelblau für Buttons
    b.Text = text
    b.TextColor3 = Color3.fromRGB(135,206,250) -- Himmelblauer Text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 16
    Instance.new("UICorner",b).CornerRadius = UDim.new(0,8)

    -- Hover-Effekt
    b.MouseEnter:Connect(function()
        b.BackgroundColor3 = Color3.fromRGB(40,80,120)
    end)
    
    b.MouseLeave:Connect(function()
        b.BackgroundColor3 = Color3.fromRGB(30,60,90)
    end)

    b.MouseButton1Click:Connect(function()
        callback()
        sendSauberLog("Button benutzt: "..text)
    end)

end

